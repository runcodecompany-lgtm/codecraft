// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?  @db.Text
  mainImage   String?  // رابط الصورة في R2 أو Supabase
  mainImageDescription String? // وصف الصورة الرئيسية
  keywords    String[] // الكلمات المفتاحية
  published   Boolean  @default(false)
  authorId    String
   author     User     @relation(fields: [authorId], references: [id])
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  views       Int      @default(0)

  @@index([slug])
}

enum Role {
  ADMIN
  WRITER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  alias     String?  // الاسم المستعار للجمهور
  email     String   @unique
  password  String?
  image     String?  // رابط الصورة الشخصية
  role      Role     @default(WRITER)
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model SiteSettings {
  id                  String   @id @default("default")
  // روابط التواصل
  facebook            String?
  twitter             String?
  instagram           String?
  youtube             String?
  whatsapp            String?
  // بيانات التواصل
  contactEmail        String?
  phoneNumber         String?
  officeAddress       String?
  // بيانات الموقع العامة
  siteName            String   @default("أخبارنا")
  siteDescription     String?
  footerCopyright     String?
  // خرائط جوجل
  googleMapsEmbedUrl  String?  @db.Text
  
  updatedAt           DateTime @updatedAt
}